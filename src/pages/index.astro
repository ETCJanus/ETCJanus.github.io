---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ewoud Janus | Interaction Technologist">
  <main class="min-h-screen flex items-center justify-center p-4">
    
<div id="cards-container" class="max-w-5xl w-full grid grid-cols-1 md:grid-cols-4 grid-rows-4 gap-4 md:h-[600px]">

      <div class="col-span-1 md:col-span-2 md:row-span-2 card-spotlight bg-slate-900/50 backdrop-blur-xl border border-white/10 rounded-3xl p-8 flex flex-col justify-between relative overflow-hidden group">
        <div class="z-10">
          <h1 class="text-5xl font-extrabold mb-2 tracking-tight">
            Hello, I'm <br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500">Ewoud Janus</span>.
          </h1>
          <p class="text-slate-400 text-lg mt-4 max-w-sm">
            I engineer tangible interfaces and digital systems.
          </p>
          <span class="text-sm text-slate-400">Interaction Technology M.Sc. at University of Twente. Specializing in Critical Making & Embodied Design.</span>
        </div>
        <div class="absolute -right-10 -bottom-10 w-64 h-64 bg-blue-600 rounded-full blur-[100px] opacity-20 group-hover:opacity-40 transition duration-700"></div>
      </div>

      <a href="/tinkering" class="col-span-1 md:col-span-2 md:row-span-1 card-spotlight bg-slate-900/50 backdrop-blur-xl border border-white/10 hover:border-blue-500 transition-all group flex items-center justify-between relative overflow-hidden cursor-pointer">
        <div class="z-10">
          <div class="flex items-center gap-2 mb-1">
            <span class="bg-green-500/20 text-green-400 text-xs font-bold px-2 py-1 rounded-full uppercase tracking-wider">Active Course</span>
          </div>
          <h2 class="text-2xl font-bold">Mastering Tinkering</h2>
          <p class="text-slate-500 text-sm">Documentation & Assignments (Q3 2026)</p>
        </div>
        <div class="bg-slate-700 p-3 rounded-full group-hover:bg-blue-600 group-hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </div>
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#4b5563 1px, transparent 1px); background-size: 20px 20px;"></div>
      </a>

      <div class="col-span-1 md:row-span-2 card-spotlight bg-slate-900/50 backdrop-blur-xl border border-white/10 rounded-3xl p-6 flex flex-col justify-center gap-4">
        <h3 class="font-bold text-slate-300">Connect</h3>
        <a href="#" class="flex items-center gap-3 text-slate-400 hover:text-white transition">
          <div class="w-8 h-8 bg-slate-700 rounded-full flex items-center justify-center">🐙</div>
          <span>GitHub</span>
        </a>
        <a href="#" class="flex items-center gap-3 text-slate-400 hover:text-white transition">
          <div class="w-8 h-8 bg-slate-700 rounded-full flex items-center justify-center">💼</div>
          <span>LinkedIn</span>
        </a>
        <a href="#" class="flex items-center gap-3 text-slate-400 hover:text-white transition">
          <div class="w-8 h-8 bg-slate-700 rounded-full flex items-center justify-center">📧</div>
          <span>Email</span>
        </a>
      </div>

      <div class="col-span-1 md:row-span-2 card-spotlight bg-slate-900/50 backdrop-blur-xl border border-white/10 rounded-3xl p-6 relative overflow-hidden">
        <h3 class="font-bold text-slate-300 mb-4">Toolkit</h3>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-slate-700 rounded-md text-xs text-slate-300">Astro</span>
          <span class="px-3 py-1 bg-slate-700 rounded-md text-xs text-slate-300">Tailwind</span>
          <span class="px-3 py-1 bg-slate-700 rounded-md text-xs text-slate-300">React</span>
          <span class="px-3 py-1 bg-slate-700 rounded-md text-xs text-slate-300">Arduino</span>
          <span class="px-3 py-1 bg-slate-700 rounded-md text-xs text-slate-300">Figma</span>
        </div>
      </div>

      <div class="col-span-1 md:col-span-2 card-spotlight bg-gradient-to-br from-violet-900 to-slate-900 rounded-3xl p-6 border border-slate-700 flex flex-col justify-end group cursor-pointer relative overflow-hidden">
        <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition"></div>
        <div class="z-10">
           <span class="text-violet-300 text-xs font-bold uppercase">Latest Project</span>
           <h3 class="text-xl font-bold mt-1">Interactive Light Installation</h3>
        </div>
      </div>

    </div>
  </main>

<script>
  const cards = document.querySelectorAll('.card-spotlight');
  
  document.getElementById('cards-container').onmousemove = e => {
    for(const card of cards) {
      const rect = card.getBoundingClientRect(),
            x = e.clientX - rect.left,
            y = e.clientY - rect.top;

      card.style.setProperty("--mouse-x", `${x}px`);
      card.style.setProperty("--mouse-y", `${y}px`);
    };
  }
</script>
</Layout>