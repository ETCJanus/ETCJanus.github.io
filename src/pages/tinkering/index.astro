---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Mastering Tinkering Portfolio">
	<main class="max-w-3xl mx-auto p-8">
		<a href="/" class="text-sm text-gray-400 hover:text-gray-800 mb-8 inline-block">← Back to Main Portfolio</a>
		
		<h1 class="text-4xl font-bold mb-2">Mastering Tinkering</h1>
		<p class="text-gray-500 mb-8">Course 201800228 • 2026</p>

		<section class="border border-gray-200 rounded-lg p-6 mb-6 hover:shadow-md transition-shadow">
			<div class="flex justify-between items-baseline mb-2">
				<h2 class="text-2xl font-semibold">0.1 Portfolio Setup</h2>
				<span class="text-sm text-gray-400">Feb 5, 2026</span>
			</div>
			<p class="mb-4">
				I built this portfolio using <strong>Astro</strong> and <strong>Tailwind CSS</strong>. 
				This setup allows me to separate my professional portfolio from my academic coursework while maintaining full design control.
			</p>
			<div class="bg-blue-50 text-blue-800 px-3 py-1 rounded inline-block text-sm font-mono">
				Status: Ready for Submission
			</div>
		</section>

		<section class="opacity-50 border border-dashed border-gray-300 rounded-lg p-6">
			<h2 class="text-xl font-semibold text-gray-400">1.1 Tinkering Spaces</h2>
			<p class="text-sm text-gray-400">Due Feb 9</p>
		</section>

	</main>
</Layout>